{
  "permissions": {
    "allow": [
      "Bash(python -m pip install:*)",
      "Bash(dir:*)",
      "Bash(findstr:*)",
      "Bash(git checkout:*)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(pip install:*)",
      "Bash(timeout:*)",
      "Bash(curl:*)",
      "Bash(powershell:*)",
      "Bash(npm run dev)",
      "Bash(tasklist:*)",
      "Bash(taskkill:*)"
    ]
  },
  "hooks": {
    "PreCommand": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/hooks/dangerous-cmd-guard.sh"
          }
        ]
      }
    ],
    "PostEdit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/hooks/post-edit-verify.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/hooks/stop-verify-check.sh"
          }
        ]
      }
    ]
  }
}
